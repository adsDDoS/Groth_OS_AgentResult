{
  "name": "ai-growth-os",
  "version": "0.1.0",
  "private": true,
  "description": "AI Growth OS template for B2B demand generation, SEO/GEO, approvals, and agentic content operations.",
  "workspaces": [
    "apps/backend",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/backend",
    "dashboard": "python3 -m http.server 4173 -d apps/dashboard",
    "backend:bundle": "esbuild apps/backend/src/main.ts --bundle --platform=node --format=cjs --packages=external --outfile=apps/backend/.runtime/backend.cjs",
    "backend:local": "HOST=127.0.0.1 node apps/backend/.runtime/backend.cjs",
    "local:agentresult": "node scripts/local-agentresult.mjs",
    "local:agentresult:demo": "node scripts/local-agentresult.mjs --reset-demo",
    "dashboard:smoke": "node scripts/dashboard-smoke.mjs",
    "agent-system:check": "node scripts/dev-agent-system-check.mjs",
    "dashboard:deploy": "npm run dashboard:smoke && npx vercel --prod --yes --cwd apps/dashboard",
    "telegram:regression": "node scripts/telegram-owner-control-regression.mjs",
    "build": "npm run build -w packages/shared && npm run build -w apps/backend",
    "start": "npm run start -w apps/backend",
    "db:migrate": "npm run db:migrate -w apps/backend",
    "db:import-local-json": "node apps/backend/dist/db/import-local-json.js",
    "demo:reset-pilot": "node apps/backend/dist/db/reset-pilot-demo.js",
    "lint": "npm run lint -w apps/backend",
    "seed:demo": "bash scripts/seed-demo-company.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
